# --- build / render output ---
out/
build/
dist/
clips/
FB-output/

# --- rendered media (final clips เก็บใน Google Drive _FB&Social แล้ว ไม่ต้องใส่ repo) ---
*.mp4
*.mov
*.webm
*.mkv

# --- installers ---
*.exe
*.msi

# --- bundled 3rd-party tools (reinstallable binaries + Java runtime, ไม่ใช่ source) ---
tools/AudiverisExtract/
tools/fluidsynth/
*.jar

# --- logs / temp / machine-local ---
*.log
.claude/settings.local.json
Thumbs.db
desktop.ini
.DS_Store
~$*
